digraph assignment1_as_is_petri {
  rankdir=LR;
  graph [label="Assignment 1 As-Is E-Purchase Petri Net", labelloc=t, fontsize=18];
  node [fontname="Arial"];
  p_start [shape=circle, peripheries=2, label="Order received", width=0.9];
  p_captured [shape=circle, peripheries=1, label="Order captured", width=0.9];
  p_stock_decision [shape=circle, peripheries=1, label="Stock checked", width=0.9];
  p_stock_available [shape=circle, peripheries=1, label="Stock available", width=0.9];
  p_reject_ready [shape=circle, peripheries=1, label="Reject path", width=0.9];
  p_address_decision [shape=circle, peripheries=1, label="Address decision", width=0.9];
  p_address_missing [shape=circle, peripheries=1, label="Missing address", width=0.9];
  p_ready_to_prepare [shape=circle, peripheries=1, label="Ready to prepare", width=0.9];
  p_payment_ready [shape=circle, peripheries=1, label="Payment branch", width=0.9];
  p_fulfillment_ready [shape=circle, peripheries=1, label="Fulfillment branch", width=0.9];
  p_payment_authorized [shape=circle, peripheries=1, label="Payment authorized", width=0.9];
  p_invoice_done [shape=circle, peripheries=1, label="Invoice emitted", width=0.9];
  p_packed [shape=circle, peripheries=1, label="Packed", width=0.9];
  p_shipped [shape=circle, peripheries=1, label="Shipped", width=0.9];
  p_wait_delivery [shape=circle, peripheries=1, label="Waiting delivery", width=0.9];
  p_delay_case [shape=circle, peripheries=1, label="Delay active", width=0.9];
  p_complaint_registered [shape=circle, peripheries=1, label="Complaint registered", width=0.9];
  p_delivery_ok [shape=circle, peripheries=1, label="Delivery confirmed", width=0.9];
  p_done [shape=doublecircle, peripheries=2, label="Case closed", width=0.9];
  t_capture_order [shape=box, style="rounded", label="Capture order"];
  t_check_stock [shape=box, style="rounded", label="Check stock"];
  t_stock_no [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: no stock"];
  t_reject_order [shape=box, style="rounded", label="Reject order"];
  t_stock_yes [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: stock available"];
  t_reserve_item [shape=box, style="rounded", label="Reserve item"];
  t_address_no [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: address missing"];
  t_request_address [shape=box, style="rounded", label="Request address"];
  t_address_yes [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: address known"];
  t_prepare_split [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: parallel split"];
  t_authorize_payment [shape=box, style="rounded", label="Authorize payment"];
  t_emit_invoice [shape=box, style="rounded", label="Emit invoice"];
  t_pick_pack [shape=box, style="rounded", label="Pick and pack"];
  t_ship_product [shape=box, style="rounded", label="Ship product"];
  t_prepare_join [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: parallel join"];
  t_delivery_confirmed [shape=box, style="rounded", label="Message: delivery confirmed"];
  t_goods_delayed [shape=box, style="rounded", label="Timer: goods delayed"];
  t_register_complaint [shape=box, style="rounded", label="Register complaint"];
  t_escalate_courier [shape=box, style="rounded", label="Escalate courier"];
  t_archive_order [shape=box, style="rounded", label="Archive order"];
  p_start -> t_capture_order;
  t_capture_order -> p_captured;
  p_captured -> t_check_stock;
  t_check_stock -> p_stock_decision;
  p_stock_decision -> t_stock_no;
  t_stock_no -> p_reject_ready;
  p_reject_ready -> t_reject_order;
  t_reject_order -> p_done;
  p_stock_decision -> t_stock_yes;
  t_stock_yes -> p_stock_available;
  p_stock_available -> t_reserve_item;
  t_reserve_item -> p_address_decision;
  p_address_decision -> t_address_no;
  t_address_no -> p_address_missing;
  p_address_missing -> t_request_address;
  t_request_address -> p_ready_to_prepare;
  p_address_decision -> t_address_yes;
  t_address_yes -> p_ready_to_prepare;
  p_ready_to_prepare -> t_prepare_split;
  t_prepare_split -> p_payment_ready;
  t_prepare_split -> p_fulfillment_ready;
  p_payment_ready -> t_authorize_payment;
  t_authorize_payment -> p_payment_authorized;
  p_payment_authorized -> t_emit_invoice;
  t_emit_invoice -> p_invoice_done;
  p_fulfillment_ready -> t_pick_pack;
  t_pick_pack -> p_packed;
  p_packed -> t_ship_product;
  t_ship_product -> p_shipped;
  p_invoice_done -> t_prepare_join;
  p_shipped -> t_prepare_join;
  t_prepare_join -> p_wait_delivery;
  p_wait_delivery -> t_delivery_confirmed;
  t_delivery_confirmed -> p_delivery_ok;
  p_delivery_ok -> t_archive_order;
  t_archive_order -> p_done;
  p_wait_delivery -> t_goods_delayed;
  t_goods_delayed -> p_delay_case;
  p_delay_case -> t_register_complaint;
  t_register_complaint -> p_complaint_registered;
  p_complaint_registered -> t_escalate_courier;
  t_escalate_courier -> p_wait_delivery;
}
