      <bpmndi:BPMNEdge id="F21_di" bpmnElement="F21">
        <di:waypoint x="1840" y="250"/>
        <di:waypoint x="1880" y="250"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F22_di" bpmnElement="F22">
        <di:waypoint x="2010" y="250"/>
