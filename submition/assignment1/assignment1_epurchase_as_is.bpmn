<?xml version="1.0" ?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Epurchase_AsIs" targetNamespace="https://cse346.local/epurchase">
  <bpmn:process id="Epurchase_AsIs" name="E-Purchase As-Is Process" isExecutable="false">
    <bpmn:laneSet id="Epurchase_AsIs_LaneSet">
      <bpmn:lane id="Epurchase_AsIs_Customer_Lane" name="Customer">
        <bpmn:flowNodeRef>Start_Order_Received</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Epurchase_AsIs_Marketplace_system_Lane" name="Marketplace system">
        <bpmn:flowNodeRef>Capture_Order</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Check_Stock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Stock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Reject_Order</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Reserve_Item</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Address</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Request_Address</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Address_Merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Parallel_Prepare</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Parallel_Ready</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Delivery_Merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Delivery_Event</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Archive_Order</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Order_Closed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Epurchase_AsIs_Payment_service_Lane" name="Payment service">
        <bpmn:flowNodeRef>Authorize_Payment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Emit_Invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Receive_Payment</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Epurchase_AsIs_Warehouse_Lane" name="Warehouse">
        <bpmn:flowNodeRef>Pick_Pack</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Epurchase_AsIs_Courier_Lane" name="Courier">
        <bpmn:flowNodeRef>Ship_Product</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Delivery_Confirmed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Goods_Delayed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Epurchase_AsIs_Customer_support_Lane" name="Customer support">
        <bpmn:flowNodeRef>Register_Complaint</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Escalate_Courier</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Order_Received" name="Order received">
      <bpmn:outgoing>F01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Capture_Order" name="Capture order">
      <bpmn:incoming>F01</bpmn:incoming>
      <bpmn:outgoing>F02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Check_Stock" name="Check stock">
      <bpmn:incoming>F02</bpmn:incoming>
      <bpmn:outgoing>F03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Stock" name="Stock available?">
      <bpmn:incoming>F03</bpmn:incoming>
      <bpmn:outgoing>F04</bpmn:outgoing>
      <bpmn:outgoing>F06</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Reject_Order" name="Reject order">
      <bpmn:incoming>F04</bpmn:incoming>
      <bpmn:outgoing>F05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Rejected" name="Order rejected">
      <bpmn:incoming>F05</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Reserve_Item" name="Reserve item">
      <bpmn:incoming>F06</bpmn:incoming>
      <bpmn:outgoing>F07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Address" name="Address known?">
      <bpmn:incoming>F07</bpmn:incoming>
      <bpmn:outgoing>F08</bpmn:outgoing>
      <bpmn:outgoing>F09</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Request_Address" name="Request address">
      <bpmn:incoming>F09</bpmn:incoming>
      <bpmn:outgoing>F10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Address_Merge" name="Address resolved">
      <bpmn:incoming>F08</bpmn:incoming>
      <bpmn:incoming>F10</bpmn:incoming>
      <bpmn:outgoing>F11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="Parallel_Prepare" name="Prepare order">
      <bpmn:incoming>F11</bpmn:incoming>
      <bpmn:outgoing>F12</bpmn:outgoing>
      <bpmn:outgoing>F15</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:task id="Authorize_Payment" name="Authorize payment">
      <bpmn:incoming>F12</bpmn:incoming>
      <bpmn:outgoing>F13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Emit_Invoice" name="Emit invoice">
      <bpmn:incoming>F13</bpmn:incoming>
      <bpmn:outgoing>F14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Receive_Payment" name="Receive payment">
      <bpmn:incoming>F14</bpmn:incoming>
      <bpmn:outgoing>F17</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Pick_Pack" name="Pick and pack">
      <bpmn:incoming>F15</bpmn:incoming>
      <bpmn:outgoing>F16</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Ship_Product" name="Ship product">
      <bpmn:incoming>F16</bpmn:incoming>
      <bpmn:outgoing>F18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:parallelGateway id="Parallel_Ready" name="Ready">
      <bpmn:incoming>F17</bpmn:incoming>
      <bpmn:incoming>F18</bpmn:incoming>
      <bpmn:outgoing>F19</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:exclusiveGateway id="Gateway_Delivery_Merge" name="Continue wait">
      <bpmn:incoming>F19</bpmn:incoming>
      <bpmn:incoming>F25</bpmn:incoming>
      <bpmn:outgoing>F20</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:eventBasedGateway id="Gateway_Delivery_Event" name="Delivery event">
      <bpmn:incoming>F20</bpmn:incoming>
      <bpmn:outgoing>F21</bpmn:outgoing>
      <bpmn:outgoing>F22</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Delivery_Confirmed" name="Delivery confirmed">
      <bpmn:messageEventDefinition/>
      <bpmn:incoming>F21</bpmn:incoming>
      <bpmn:outgoing>F26</bpmn:outgoing>
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Goods_Delayed" name="Goods delayed">
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
      <bpmn:incoming>F22</bpmn:incoming>
      <bpmn:outgoing>F23</bpmn:outgoing>
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Register_Complaint" name="Register complaint">
      <bpmn:incoming>F23</bpmn:incoming>
      <bpmn:outgoing>F24</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Escalate_Courier" name="Escalate courier">
      <bpmn:incoming>F24</bpmn:incoming>
      <bpmn:outgoing>F25</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Archive_Order" name="Archive order">
      <bpmn:incoming>F26</bpmn:incoming>
      <bpmn:outgoing>F27</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Order_Closed" name="Order closed">
      <bpmn:incoming>F27</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F01" sourceRef="Start_Order_Received" targetRef="Capture_Order"/>
    <bpmn:sequenceFlow id="F02" sourceRef="Capture_Order" targetRef="Check_Stock"/>
    <bpmn:sequenceFlow id="F03" sourceRef="Check_Stock" targetRef="Gateway_Stock"/>
    <bpmn:sequenceFlow id="F04" sourceRef="Gateway_Stock" targetRef="Reject_Order" name="No"/>
    <bpmn:sequenceFlow id="F05" sourceRef="Reject_Order" targetRef="End_Rejected"/>
    <bpmn:sequenceFlow id="F06" sourceRef="Gateway_Stock" targetRef="Reserve_Item" name="Yes"/>
    <bpmn:sequenceFlow id="F07" sourceRef="Reserve_Item" targetRef="Gateway_Address"/>
    <bpmn:sequenceFlow id="F08" sourceRef="Gateway_Address" targetRef="Gateway_Address_Merge" name="Yes"/>
    <bpmn:sequenceFlow id="F09" sourceRef="Gateway_Address" targetRef="Request_Address" name="No"/>
    <bpmn:sequenceFlow id="F10" sourceRef="Request_Address" targetRef="Gateway_Address_Merge"/>
    <bpmn:sequenceFlow id="F11" sourceRef="Gateway_Address_Merge" targetRef="Parallel_Prepare"/>
    <bpmn:sequenceFlow id="F12" sourceRef="Parallel_Prepare" targetRef="Authorize_Payment"/>
    <bpmn:sequenceFlow id="F13" sourceRef="Authorize_Payment" targetRef="Emit_Invoice"/>
    <bpmn:sequenceFlow id="F14" sourceRef="Emit_Invoice" targetRef="Receive_Payment"/>
    <bpmn:sequenceFlow id="F15" sourceRef="Parallel_Prepare" targetRef="Pick_Pack"/>
    <bpmn:sequenceFlow id="F16" sourceRef="Pick_Pack" targetRef="Ship_Product"/>
    <bpmn:sequenceFlow id="F17" sourceRef="Receive_Payment" targetRef="Parallel_Ready"/>
    <bpmn:sequenceFlow id="F18" sourceRef="Ship_Product" targetRef="Parallel_Ready"/>
    <bpmn:sequenceFlow id="F19" sourceRef="Parallel_Ready" targetRef="Gateway_Delivery_Merge"/>
    <bpmn:sequenceFlow id="F20" sourceRef="Gateway_Delivery_Merge" targetRef="Gateway_Delivery_Event"/>
    <bpmn:sequenceFlow id="F21" sourceRef="Gateway_Delivery_Event" targetRef="Delivery_Confirmed" name="Delivered"/>
    <bpmn:sequenceFlow id="F22" sourceRef="Gateway_Delivery_Event" targetRef="Goods_Delayed" name="2 days late"/>
    <bpmn:sequenceFlow id="F23" sourceRef="Goods_Delayed" targetRef="Register_Complaint"/>
    <bpmn:sequenceFlow id="F24" sourceRef="Register_Complaint" targetRef="Escalate_Courier"/>
    <bpmn:sequenceFlow id="F25" sourceRef="Escalate_Courier" targetRef="Gateway_Delivery_Merge"/>
    <bpmn:sequenceFlow id="F26" sourceRef="Delivery_Confirmed" targetRef="Archive_Order"/>
    <bpmn:sequenceFlow id="F27" sourceRef="Archive_Order" targetRef="End_Order_Closed"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_Epurchase_AsIs">
    <bpmndi:BPMNPlane id="Plane_Epurchase_AsIs" bpmnElement="Epurchase_AsIs">
