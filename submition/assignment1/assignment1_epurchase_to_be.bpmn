      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Fulfillment_Join_di" bpmnElement="Fulfillment_Join">
        <dc:Bounds x="1610" y="153" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Track_Shipment_di" bpmnElement="Track_Shipment">
        <dc:Bounds x="1700" y="146" width="130" height="64"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SLA_di" bpmnElement="Gateway_SLA">
        <dc:Bounds x="1880" y="153" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Delivery_Confirmed_di" bpmnElement="Delivery_Confirmed">
        <dc:Bounds x="1980" y="92" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SLA_Breach_di" bpmnElement="SLA_Breach">
        <dc:Bounds x="1980" y="232" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Open_Complaint_di" bpmnElement="Open_Complaint">
        <dc:Bounds x="2060" y="218" width="130" height="64"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Notify_Customer_di" bpmnElement="Notify_Customer">
        <dc:Bounds x="2230" y="218" width="130" height="64"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Expedite_Courier_di" bpmnElement="Expedite_Courier">
        <dc:Bounds x="2400" y="218" width="130" height="64"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Archive_Order_di" bpmnElement="Archive_Order">
        <dc:Bounds x="2230" y="78" width="130" height="64"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_Closed_di" bpmnElement="End_Closed">
        <dc:Bounds x="2410" y="92" width="36" height="36"/>
      </bpmndi:BPMNShape>
