      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Emit_Invoice_di" bpmnElement="Emit_Invoice">
        <dc:Bounds x="1100" y="70" width="130" height="64"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Create_Label_di" bpmnElement="Create_Label">
