digraph assignment1_to_be_petri {
  rankdir=LR;
  graph [label="Assignment 1 To-Be E-Purchase Petri Net", labelloc=t, fontsize=18];
  node [fontname="Arial"];
  p_start [shape=circle, peripheries=2, label="Checkout submitted", width=0.9];
  p_validated [shape=circle, peripheries=1, label="Order validated", width=0.9];
  p_stock_ready [shape=circle, peripheries=1, label="Stock check ready", width=0.9];
  p_payment_ready [shape=circle, peripheries=1, label="Payment check ready", width=0.9];
  p_stock_checked [shape=circle, peripheries=1, label="Stock checked", width=0.9];
  p_payment_checked [shape=circle, peripheries=1, label="Payment checked", width=0.9];
  p_order_decision [shape=circle, peripheries=1, label="Order decision", width=0.9];
  p_reject_ready [shape=circle, peripheries=1, label="Reject path", width=0.9];
  p_reserve_ready [shape=circle, peripheries=1, label="Ready to reserve", width=0.9];
  p_fulfillment_reserved [shape=circle, peripheries=1, label="Fulfillment reserved", width=0.9];
  p_invoice_ready [shape=circle, peripheries=1, label="Invoice branch", width=0.9];
  p_label_ready [shape=circle, peripheries=1, label="Label branch", width=0.9];
  p_invoice_done [shape=circle, peripheries=1, label="Invoice emitted", width=0.9];
  p_payment_received [shape=circle, peripheries=1, label="Payment received", width=0.9];
  p_label_created [shape=circle, peripheries=1, label="Label created", width=0.9];
  p_packed [shape=circle, peripheries=1, label="Packed", width=0.9];
  p_shipped [shape=circle, peripheries=1, label="Shipped", width=0.9];
  p_tracking_ready [shape=circle, peripheries=1, label="Tracking ready", width=0.9];
  p_sla_wait [shape=circle, peripheries=1, label="Waiting SLA event", width=0.9];
  p_delay_case [shape=circle, peripheries=1, label="Delay active", width=0.9];
  p_complaint_open [shape=circle, peripheries=1, label="Complaint open", width=0.9];
  p_customer_notified [shape=circle, peripheries=1, label="Customer notified", width=0.9];
  p_delivery_ok [shape=circle, peripheries=1, label="Delivery confirmed", width=0.9];
  p_done [shape=doublecircle, peripheries=2, label="Case closed", width=0.9];
  t_validate_order [shape=box, style="rounded", label="Validate order"];
  t_auto_checks_split [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: automated checks split"];
  t_check_stock [shape=box, style="rounded", label="Check stock"];
  t_authorize_payment [shape=box, style="rounded", label="Authorize payment"];
  t_checks_join [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: checks join"];
  t_invalid_order [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: invalid order"];
  t_notify_rejection [shape=box, style="rounded", label="Notify rejection"];
  t_valid_order [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: valid order"];
  t_reserve_fulfillment [shape=box, style="rounded", label="Reserve fulfillment"];
  t_fulfill_split [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: fulfillment split"];
  t_emit_invoice [shape=box, style="rounded", label="Emit invoice"];
  t_receive_payment [shape=box, style="rounded", label="Receive payment"];
  t_create_label [shape=box, style="rounded", label="Create label"];
  t_pack_order [shape=box, style="rounded", label="Pack order"];
  t_ship_product [shape=box, style="rounded", label="Ship product"];
  t_fulfillment_join [shape=box, fillcolor="#f4f4f4", style="filled,dashed,rounded", label="silent: fulfillment join"];
  t_track_shipment [shape=box, style="rounded", label="Track shipment"];
  t_delivery_confirmed [shape=box, style="rounded", label="Message: delivery confirmed"];
  t_sla_breached [shape=box, style="rounded", label="Timer: SLA breached"];
  t_open_complaint [shape=box, style="rounded", label="Open complaint"];
  t_notify_customer [shape=box, style="rounded", label="Notify customer"];
  t_expedite_courier [shape=box, style="rounded", label="Expedite courier"];
  t_archive_order [shape=box, style="rounded", label="Archive order"];
  p_start -> t_validate_order;
  t_validate_order -> p_validated;
  p_validated -> t_auto_checks_split;
  t_auto_checks_split -> p_stock_ready;
  t_auto_checks_split -> p_payment_ready;
  p_stock_ready -> t_check_stock;
  t_check_stock -> p_stock_checked;
  p_payment_ready -> t_authorize_payment;
  t_authorize_payment -> p_payment_checked;
  p_stock_checked -> t_checks_join;
  p_payment_checked -> t_checks_join;
  t_checks_join -> p_order_decision;
  p_order_decision -> t_invalid_order;
  t_invalid_order -> p_reject_ready;
  p_reject_ready -> t_notify_rejection;
  t_notify_rejection -> p_done;
  p_order_decision -> t_valid_order;
  t_valid_order -> p_reserve_ready;
  p_reserve_ready -> t_reserve_fulfillment;
  t_reserve_fulfillment -> p_fulfillment_reserved;
  p_fulfillment_reserved -> t_fulfill_split;
  t_fulfill_split -> p_invoice_ready;
  t_fulfill_split -> p_label_ready;
  p_invoice_ready -> t_emit_invoice;
  t_emit_invoice -> p_invoice_done;
  p_invoice_done -> t_receive_payment;
  t_receive_payment -> p_payment_received;
  p_label_ready -> t_create_label;
  t_create_label -> p_label_created;
  p_label_created -> t_pack_order;
  t_pack_order -> p_packed;
  p_packed -> t_ship_product;
  t_ship_product -> p_shipped;
  p_payment_received -> t_fulfillment_join;
  p_shipped -> t_fulfillment_join;
  t_fulfillment_join -> p_tracking_ready;
  p_tracking_ready -> t_track_shipment;
  t_track_shipment -> p_sla_wait;
  p_sla_wait -> t_delivery_confirmed;
  t_delivery_confirmed -> p_delivery_ok;
  p_delivery_ok -> t_archive_order;
  t_archive_order -> p_done;
  p_sla_wait -> t_sla_breached;
  t_sla_breached -> p_delay_case;
  p_delay_case -> t_open_complaint;
  t_open_complaint -> p_complaint_open;
  p_complaint_open -> t_notify_customer;
  t_notify_customer -> p_customer_notified;
  p_customer_notified -> t_expedite_courier;
  t_expedite_courier -> p_sla_wait;
}
